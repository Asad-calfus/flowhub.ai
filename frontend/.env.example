# Base URL of the FastAPI backend (Phase 5+), including the /api/v1 prefix.
# The docker-compose "backend" service listens on host port 8001; a local
# `uvicorn --port 8001` run uses the same value.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001/api/v1

# Absolute path to the backend's results directory, used only by the read-only
# evaluation route (app/api/evaluation/route.ts) to render existing metric
# files. Not used for any other page - never for feedback/theme/report data.
BACKEND_RESULTS_DIR=../backend/results
