# LLM provider used by the few-shot classifier (src/classification/classifier.py).
# "openai", "anthropic", or "groq" (OpenAI-compatible API, routed through the same
# OpenAI client with a different base URL - see classifier.py::GROQ_BASE_URL).
# NOTE: the Phase 6 weekly-report narrative generator
# (src/reports/generator.py::LLMReportGenerator) reads the same LLM_PROVIDER/LLM_MODEL
# variables but does NOT yet support "groq" - only "openai"/"anthropic" - see
# docs/changelog/0017-groq-classifier-provider.md.
LLM_PROVIDER=openai

# Model name for the configured provider. Cost-efficient defaults:
#   openai:    gpt-4o-mini            (~$0.15 / $0.60 per 1M input/output tokens)
#   anthropic: claude-haiku-4-5-20251001
#   groq:      llama-3.1-8b-instant   (~$0.05 / $0.08 per 1M input/output tokens, approx)
LLM_MODEL=gpt-4o-mini

# API key for the configured provider. Set only ONE of these - never commit a real key,
# this file is a template only.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Optional: request timeout in seconds for LLM calls.
LLM_TIMEOUT_SECONDS=30

# Phase 5 - FastAPI + PostgreSQL backend
# --------------------------------------
# Postgres connection string (psycopg 3 driver). The docker-compose "backend" service
# overrides this to point at the "db" container instead - see ../docker-compose.yml.
DATABASE_URL=postgresql+psycopg://flowhub:flowhub@localhost:5433/flowhub

# Comma-separated list of origins allowed by CORS (for the future frontend).
CORS_ORIGINS=http://localhost:3000
