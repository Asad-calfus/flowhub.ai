# LLM provider used by the few-shot classifier: "openai" or "anthropic".
LLM_PROVIDER=openai

# Model name for the configured provider. Cost-efficient defaults:
#   openai:    gpt-4o-mini   (~$0.15 / $0.60 per 1M input/output tokens)
#   anthropic: claude-haiku-4-5-20251001
LLM_MODEL=gpt-4o-mini

# API key for the configured provider. Set only ONE of these - never commit a real key,
# this file is a template only.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: request timeout in seconds for LLM calls.
LLM_TIMEOUT_SECONDS=30

# Phase 5 - FastAPI + PostgreSQL backend
# --------------------------------------
# Postgres connection string (psycopg 3 driver). The docker-compose "backend" service
# overrides this to point at the "db" container instead - see ../docker-compose.yml.
DATABASE_URL=postgresql+psycopg://flowhub:flowhub@localhost:5433/flowhub

# Comma-separated list of origins allowed by CORS (for the future frontend).
CORS_ORIGINS=http://localhost:3000
